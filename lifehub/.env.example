PORT=3000
MONGODB_URI=mongodb://localhost:27017/lifehub
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Public URL of this server — used in password-reset email links
APP_URL=http://localhost:3000

# Public URL of the web client — used for invite links and CORS
CLIENT_URL=http://localhost:8080

# MongoDB authentication (required when using docker-compose)
# Generate a strong password: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MONGO_ROOT_USER=lifehub
MONGO_ROOT_PASSWORD=changeme_strong_password_here

# Fallback email vars (overridden by admin dashboard config stored in DB)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

LOG_LEVEL=info
NODE_ENV=production

# Telegram Bot (optional — bot disabled if not set)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com
# Set to 'true' for local development (uses long-polling instead of webhook)
TELEGRAM_USE_POLLING=false
