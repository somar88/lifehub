# ── Required ──────────────────────────────────────────────────────────────────
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme_use_random_64chars

# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=changeme_use_random_64hex_chars

APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:8080

# ── Optional (server defaults apply if omitted) ────────────────────────────────
JWT_EXPIRES_IN=7d
LOG_LEVEL=info

# ── Email (optional — configure later via admin dashboard) ────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Telegram (optional — bot is disabled when token is not set) ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_USE_POLLING=true
